# Copy to .env at the repo root. The Taskfile auto-loads it.

# Slack app credentials. Create at https://api.slack.com/apps → "From scratch".
# OAuth & Permissions → redirect URL: http://localhost:7880/slack/oauth/callback
# Event Subscriptions → request URL: http://<your-tunnel>/slack/events
#                       bot events:  message.channels, message.groups, message.im
# Bot Token Scopes: chat:write, channels:history, channels:read,
#                   groups:history, groups:read, im:history, im:read, im:write,
#                   users:read
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Optional: if you already installed the app manually, drop a bot token here
# and the sidecar will skip the OAuth flow entirely.
# SLACK_BOT_TOKEN=xoxb-...

# ============================================================
# OPTION A — Socket Mode (recommended for local dev)
#   No tunnel, no public URL, no signing secret verification.
#   Slack app setup:
#     1. App → Socket Mode → enable
#     2. App → Basic Information → App-Level Tokens → Generate Token
#        with scope connections:write; copy the xapp-... token below
#     3. Event Subscriptions → enable (no request URL needed) →
#        Subscribe to bot events: message.channels (etc.)
#     4. Reinstall the app
# ============================================================
# SLACK_APP_TOKEN=xapp-...

# ============================================================
# OPTION B — HTTP Events API (requires a public URL)
#   Only used when SLACK_APP_TOKEN is NOT set. Needs a tunnel:
#     task tunnel:bg     (cloudflared)
#     task tunnel:slack-config   (prints paste-ready URL)
# ============================================================

# Where the sidecar stores the bot token after OAuth. Default shown.
# ORCA_SLACK_TOKEN_PATH=${HOME}/.orca/slack-token.json

# Orca wiring. These are the defaults; override only if you need to.
# ORCA_ADDR=http://localhost:7878
# ORCA_SLACK_LISTEN=:7880
# ORCA_SLACK_AGENT_ID=slack

# If you're tunnelling through ngrok/cloudflared for the slack events URL,
# set this so the OAuth redirect_uri matches what your Slack app has configured.
# ORCA_SLACK_PUBLIC_URL=https://abc123.ngrok.io

# Optional YAML file with channel→agent routing rules. See examples/slack.yaml.
# ORCA_SLACK_CONFIG=examples/slack.yaml
